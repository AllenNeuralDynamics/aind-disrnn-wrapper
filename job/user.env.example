# Per-user settings for slurm jobs in this repo.
#
# Copy this file to job/user.env (gitignored) and edit the values:
#
#     cp job/user.env.example job/user.env
#
# Then add one line to your ~/.bashrc so it loads in every shell:
#
#     echo 'source /path/to/aind-disrnn-wrapper/job/user.env' >> ~/.bashrc
#
# The SBATCH_* variables are read by sbatch automatically; no extra flags
# needed. CONDA_SH is read by the slurm scripts themselves.

# Email for SLURM mail-type=FAIL,END,BEGIN notifications.
export SBATCH_MAIL_USER="you@alleninstitute.org"

# Where SLURM should write per-job stdout/stderr. Use %j for the job id.
export SBATCH_OUTPUT="$HOME/logfile/job_%j.out"
export SBATCH_ERROR="$HOME/logfile/job_%j.err"

# Absolute path to your conda's profile.d/conda.sh (so the slurm script can
# 'source' it and then 'conda activate disrnn-cpu|gpu'). Find yours with:
#     echo "$(conda info --base)/etc/profile.d/conda.sh"
export CONDA_SH="/path/to/your/miniforge3/etc/profile.d/conda.sh"
